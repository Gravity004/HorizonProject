{
  "version": 2,
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/api/index.js"
    },
    {
      "source": "/dashboard",
      "destination": "/api/index.js"
    },
    {
      "source": "/dashboard.html",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.js"
    }
  ]
}